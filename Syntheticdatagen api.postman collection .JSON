              "mode": "raw",
              "raw": "{\n  \"connection_name\": \"{{connection_name}}\",\n  \"table\": \"tstg_aa_accountdetail\",\n  \"format\": \"csv\",\n  \"limit\": 10000,\n  \"filters\": {}\n}"
